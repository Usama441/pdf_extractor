<% content_for :title, "Sign In" %>

<section class="auth-shell">
  <div class="auth-panel">
    <p class="eyebrow">Secure statement processing</p>
    <h1>Sign in to continue</h1>
    <p class="lede">
      Your dashboard keeps every extraction job, result preview, and downloadable Excel export
      tied to your account.
    </p>
    <%= render "shared/bank_ticker" %>
  </div>

  <div class="auth-card">
    <%= form_with url: login_path, class: "stack-form" do |form| %>
      <div class="field">
        <%= form.label :email %>
        <%= form.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com" %>
      </div>

      <div class="field">
        <%= form.label :password %>
        <%= form.password_field :password, autocomplete: "current-password" %>
      </div>

      <%= form.submit "Sign in", class: "button button--dark button--block" %>
    <% end %>

    <p class="auth-footnote">
      New here?
      <%= link_to "Create an account", signup_path %>
    </p>
  </div>
</section>
